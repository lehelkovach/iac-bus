{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iac-bus.local/schemas/iac-bus.schema.json",
  "title": "IAC Bus Protocol",
  "type": "object",
  "description": "Schema definitions for IAC Bus message and queue endpoints.",
  "$defs": {
    "MessageCreate": {
      "type": "object",
      "required": [
        "message"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "default": "default"
        },
        "sender": {
          "type": "string",
          "default": "agent"
        },
        "message": {
          "description": "Payload",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            },
            {
              "type": "array"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "type": {
          "type": "string",
          "default": "event"
        },
        "conversation_id": {
          "type": "string"
        },
        "reply_to": {
          "type": "string"
        },
        "recipient": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "queue": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "default": 0
        },
        "headers": {
          "type": "object"
        },
        "ttl_seconds": {
          "type": "number",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "Message": {
      "type": "object",
      "required": [
        "id",
        "ts",
        "channel",
        "sender",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "ts": {
          "type": "number"
        },
        "channel": {
          "type": "string"
        },
        "sender": {
          "type": "string"
        },
        "message": {
          "description": "Payload",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            },
            {
              "type": "array"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "type": {
          "type": "string"
        },
        "conversation_id": {
          "type": "string"
        },
        "reply_to": {
          "type": "string"
        },
        "recipient": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "queue": {
          "type": "string"
        },
        "priority": {
          "type": "integer"
        },
        "headers": {
          "type": "object"
        },
        "ttl_seconds": {
          "type": "number",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "published",
            "pending",
            "leased"
          ]
        },
        "leased_by": {
          "type": "string"
        },
        "lease_until": {
          "type": "number"
        },
        "lease_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "QueueClaimRequest": {
      "type": "object",
      "required": [
        "queue",
        "worker"
      ],
      "properties": {
        "queue": {
          "type": "string"
        },
        "worker": {
          "type": "string"
        },
        "lease_seconds": {
          "type": "number",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "QueueAckRequest": {
      "type": "object",
      "required": [
        "queue",
        "message_id",
        "worker",
        "lease_id"
      ],
      "properties": {
        "queue": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        },
        "worker": {
          "type": "string"
        },
        "lease_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QueueNackRequest": {
      "type": "object",
      "required": [
        "queue",
        "message_id",
        "worker",
        "lease_id",
        "requeue"
      ],
      "properties": {
        "queue": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        },
        "worker": {
          "type": "string"
        },
        "lease_id": {
          "type": "string"
        },
        "requeue": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
