{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iac-bus.local/schemas/agent-contract.schema.json",
  "title": "Universal Agent Contract",
  "type": "object",
  "description": "Portable agent control envelope for commands, events, and status.",
  "$defs": {
    "AgentKind": {
      "type": "string",
      "enum": [
        "command",
        "event",
        "status",
        "response",
        "control",
        "heartbeat",
        "registration"
      ]
    },
    "AgentState": {
      "type": "string",
      "enum": [
        "idle",
        "running",
        "waiting_input",
        "paused",
        "completed",
        "failed",
        "cancelled",
        "timed_out"
      ]
    },
    "AgentAction": {
      "type": "string",
      "enum": [
        "register",
        "heartbeat",
        "start_task",
        "pause_task",
        "resume_task",
        "cancel_task",
        "request_input",
        "provide_input",
        "claim_work",
        "ack_work",
        "nack_work",
        "report_status",
        "report_result",
        "update_policy"
      ]
    },
    "AgentPolicy": {
      "type": "object",
      "properties": {
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denylist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost": {
          "type": "number",
          "minimum": 0
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspace": {
          "type": "string"
        },
        "env": {
          "type": "object"
        },
        "secrets_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "AgentLease": {
      "type": "object",
      "properties": {
        "queue": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        },
        "lease_id": {
          "type": "string"
        },
        "lease_until": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "kind",
    "action",
    "from"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "ts": {
      "type": "number"
    },
    "protocol": {
      "type": "string",
      "default": "iac-agent/1.0"
    },
    "kind": {
      "$ref": "#/$defs/AgentKind"
    },
    "action": {
      "$ref": "#/$defs/AgentAction"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "conversation_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "reply_to": {
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/AgentState"
    },
    "payload": {
      "type": "object"
    },
    "policy": {
      "$ref": "#/$defs/AgentPolicy"
    },
    "lease": {
      "$ref": "#/$defs/AgentLease"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
